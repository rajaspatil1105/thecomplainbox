# MySQL Configuration
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=sscrms_user
MYSQL_PASSWORD=sscrms_secure_password_123
MYSQL_DATABASE=sscrms_db
MYSQL_ROOT_PASSWORD=root_secure_password_123

# MongoDB Configuration
MONGO_URI=mongodb://mongodb:27017/sscrms_db

# Redis Configuration
REDIS_URL=redis://redis:6379

# Backend Configuration
NODE_ENV=development
BACKEND_PORT=4000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=8h

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# AI Service Configuration
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_PORT=8000
GEMINI_API_KEY=your-gemini-api-key-here

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM_EMAIL=noreply@sscrms.edu
SMTP_FROM_NAME=SSCRMS

# File Upload Configuration
MAX_FILE_SIZE_KB=10240
MAX_FILES_PER_SUBMISSION=3
UPLOAD_PATH=./uploads

# Gemini API Limits
GEMINI_RATE_LIMIT_RPM=15
GEMINI_RATE_LIMIT_RPD=1500

# TF-IDF Configuration
TFIDF_CACHE_SIZE=200
TFIDF_CACHE_TTL=21600
TFIDF_THRESHOLD=0.78

# Application Configuration
LOG_LEVEL=info
COMPLAINT_MIN_DESCRIPTION_LENGTH=30
